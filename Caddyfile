(security) {
	header {
		# Enable HSTS
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		# Prevent clickjacking
		X-Frame-Options "SAMEORIGIN"

		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"

		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"

		# Permissions policy
		Permissions-Policy "geolocation=(), microphone=(), camera=()"

		# Content Security Policy (Next.js + Laravel).
		# Wildcards are scoped to the platform root domain instead of "https://*"
		# so an injected script cannot load from / exfiltrate to an arbitrary host.
		# 'unsafe-eval' is retained because the editor (Monaco) and WASM tooling
		# (pdfjs, ffmpeg, background-removal) require it; migrate to nonce + 'wasm-unsafe-eval'
		# once the frontend emits per-request nonces.
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.{$ROOT_DOMAIN:gulfingot.com}; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.{$ROOT_DOMAIN:gulfingot.com} wss://*.{$ROOT_DOMAIN:gulfingot.com}; worker-src 'self' blob:; frame-src 'self' blob: https://www.google.com https://maps.google.com; upgrade-insecure-requests;"

		# Remove identifying headers
		-X-Powered-By
		-Server
	}
}

{
	admin :2019
	on_demand_tls {
		ask http://backend:8000/api/internal/caddy/allow-domain
	}
}

{$FRONTEND_DOMAIN} {
	import security
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /sanctum/* {
		reverse_proxy backend:8000
	}

	handle /storage/* {
		reverse_proxy backend:8000
	}

	handle /tenancy/assets/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$BACKEND_DOMAIN} {
	import security
	encode zstd gzip
	reverse_proxy backend:8000
}

{$REVERB_DOMAIN} {
	import security
	encode zstd gzip
	reverse_proxy reverb:9000
}

{$HORIZON_DOMAIN} {
	import security
	encode zstd gzip
	reverse_proxy backend:8000
}

# NOTE: Meilisearch, Grafana, rembg and gotenberg are intentionally NOT exposed
# publicly. The application reaches them over the private Docker network
# (*_INTERNAL_URL). Grafana/Meilisearch are reachable for ops via the
# 127.0.0.1-bound host ports declared in docker-compose.prod.yml (use an SSH tunnel).

https:// {
	import security
	tls {
		on_demand
	}

	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /sanctum/* {
		reverse_proxy backend:8000
	}

	handle /storage/* {
		reverse_proxy backend:8000
	}

	handle /tenancy/assets/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}


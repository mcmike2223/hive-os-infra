http://gubae.techiveet.com, https://gubae.techiveet.com {
	encode zstd gzip

	handle /api/* {
		reverse_proxy zoom-clone-backend:5001
	}
	handle /socket.io/* {
		reverse_proxy zoom-clone-backend:5001
	}
	handle /health {
		reverse_proxy zoom-clone-backend:5001
	}

	handle {
		reverse_proxy zoom-clone-frontend:80
	}
}

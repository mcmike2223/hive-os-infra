# ==========================================
# HIVE PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# 1. DOMAIN & NETWORK CONFIGURATION
ROOT_DOMAIN=gulfingot.com
SERVER_IP=YOUR_SERVER_PUBLIC_IP_HERE
# The deploy script mirrors SERVER_IP into NEXT_PUBLIC_SERVER_IP for admin DNS hints.
# Quick switch example:
#   bash scripts/deploy-prod.sh --root-domain gulfingot.com --server-ip 49.13.211.106
# DNS tip: create a wildcard record like *.gulfingot.com -> YOUR_SERVER_PUBLIC_IP_HERE.
# If you control the Cloudflare zone yourself, you can use CADDY_TLS_MODE=cloudflare
# and a Cloudflare API token for wildcard origin TLS while keeping the proxy enabled.
# If your provider manages Cloudflare for you, use CADDY_TLS_MODE=on_demand instead.
# Cloudflare SSL/TLS mode should be set to Full (strict) for proxied records.
DOCKER_DNS_1=1.1.1.1
DOCKER_DNS_2=8.8.8.8
CADDY_TLS_MODE=on_demand
CF_API_TOKEN=YOUR_CLOUDFLARE_SCOPED_API_TOKEN_HERE
FRONTEND_DOMAIN=hive.gulfingot.com
BACKEND_DOMAIN=hive-backend.gulfingot.com
REVERB_DOMAIN=hive-ws.gulfingot.com
HORIZON_DOMAIN=hive-queue.gulfingot.com
MEILISEARCH_DOMAIN=hive-search.gulfingot.com
REMBG_DOMAIN=hive-rembg.gulfingot.com
GOTENBERG_DOMAIN=hive-docs.gulfingot.com
REDIS_DOMAIN=hive-redis.gulfingot.com
DB_DOMAIN=hive-db.gulfingot.com
BACKEND_INTERNAL_URL=http://backend:8000
FRONTEND_INTERNAL_URL=http://frontend:3000
REVERB_INTERNAL_URL=http://reverb:9000
QUEUE_INTERNAL_HOST=queue
DB_INTERNAL_HOST=db
REDIS_INTERNAL_HOST=redis
MEILISEARCH_INTERNAL_URL=http://meilisearch:7700
REMBG_INTERNAL_URL=http://rembg:5000
GOTENBERG_INTERNAL_URL=http://gotenberg:3000

# 2. BASE CONFIGURATION
APP_NAME=Hive
APP_ENV=production
# Generate this using: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://hive-backend.gulfingot.com
FRONTEND_URL=https://hive.gulfingot.com
TENANCY_CENTRAL_DOMAINS=hive.gulfingot.com,hive-backend.gulfingot.com,hive-queue.gulfingot.com

# 3. DATABASE CONFIGURATION
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_HOST_PORT=5432
DB_DATABASE=hive
DB_USERNAME=hive
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE

# 4. REDIS & CACHE
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
SESSION_DOMAIN=.gulfingot.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=hive.gulfingot.com,hive-backend.gulfingot.com,hive-queue.gulfingot.com

# 5. SEARCH (MEILISEARCH)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=YOUR_SECURE_MEILI_MASTER_KEY_HERE

# 5B. OBJECT STORAGE (SEAWEEDFS S3 API)
FILESYSTEM_DISK=s3
MEDIA_DISK=s3
AWS_ACCESS_KEY_ID=hive-seaweedfs
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_A_LONG_RANDOM_SEAWEEDFS_SECRET
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=hive-production
AWS_ENDPOINT=http://seaweedfs:8333
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true
SEAWEEDFS_ACCESS_KEY=hive-seaweedfs
SEAWEEDFS_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SEAWEEDFS_SECRET
SEAWEEDFS_BUCKET=hive-production
SEAWEEDFS_BROWSER_HOST_PORT=9091

# 5C. CORS
# Add extra patterns here later if you attach tenant domains outside *.gulfingot.com.
CORS_ALLOWED_ORIGINS=https://hive.gulfingot.com
CORS_ALLOWED_ORIGIN_PATTERNS=#^https://([a-zA-Z0-9-]+\.)?gulfingot\.com\z#

# 6. WEBSOCKETS (REVERB)
BROADCAST_CONNECTION=reverb
# Backend config
REVERB_APP_ID=123456
REVERB_APP_KEY=YOUR_SECURE_REVERB_APP_KEY
REVERB_APP_SECRET=YOUR_SECURE_REVERB_APP_SECRET
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=9000
REVERB_HOST=reverb
REVERB_PORT=9000
REVERB_SCHEME=http
# Next.js config (these values are baked into the frontend build)
NEXT_PUBLIC_REVERB_APP_KEY=YOUR_SECURE_REVERB_APP_KEY
NEXT_PUBLIC_REVERB_HOST=hive-ws.gulfingot.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https

# 7. FRONTEND NEXT.JS CONFIGURATION
NEXT_PUBLIC_API_URL=https://hive-backend.gulfingot.com/api/v1
NEXT_PUBLIC_APP_URL=https://hive.gulfingot.com
NEXT_PUBLIC_CENTRAL_DOMAINS=hive.gulfingot.com,hive-backend.gulfingot.com
NEXT_PUBLIC_ROOT_DOMAIN=gulfingot.com
NEXT_PUBLIC_FRONTEND_DOMAIN=hive.gulfingot.com
NEXT_PUBLIC_BACKEND_DOMAIN=hive-backend.gulfingot.com
NEXT_PUBLIC_REVERB_DOMAIN=hive-ws.gulfingot.com
INTERNAL_API_URL=http://backend:8000/api/v1

# 8. OPTIONAL DASHBOARD URLS
QUEUE_DASHBOARD_URL=https://hive-queue.gulfingot.com/horizon

REDIS_CLIENT=predis

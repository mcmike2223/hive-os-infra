{
	admin :2019
}

(security) {
	header {
		# Enable HSTS
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		# Prevent clickjacking
		X-Frame-Options "SAMEORIGIN"

		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"

		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"

		# Permissions policy
		Permissions-Policy "geolocation=(), microphone=(), camera=()"

		# Content Security Policy (Next.js + Laravel).
		# Wildcards scoped to the platform root domain instead of "https://*" so an
		# injected script cannot load from / exfiltrate to an arbitrary host.
		# 'unsafe-eval' retained for Monaco editor + WASM tooling (pdfjs/ffmpeg/bg-removal);
		# migrate to nonce + 'wasm-unsafe-eval' once the frontend emits per-request nonces.
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.{$ROOT_DOMAIN:gulfingot.com}; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.{$ROOT_DOMAIN:gulfingot.com} wss://*.{$ROOT_DOMAIN:gulfingot.com}; worker-src 'self' blob:; frame-src 'self' blob: https://www.google.com https://maps.google.com; upgrade-insecure-requests;"

		# Remove identifying headers
		-X-Powered-By
		-Server
	}
}

{$ROOT_DOMAIN:gulfingot.com}, {$FRONTEND_DOMAIN:hive.gulfingot.com}, *.{$ROOT_DOMAIN:gulfingot.com} {
	import security
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /sanctum/* {
		reverse_proxy backend:8000
	}

	handle /storage/* {
		reverse_proxy backend:8000
	}

	handle /tenancy/assets/* {
		reverse_proxy backend:8000
	}

	reverse_proxy frontend:3000
}

{$BACKEND_DOMAIN:hive-backend.gulfingot.com} {
	import security
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}

	@horizon path /horizon /horizon/*
	redir @horizon https://{$HORIZON_DOMAIN:hive-queue.gulfingot.com}{uri} 308

	# Keep WebSocket upgrades working on the API domain for older clients.
	handle_path /app/* {
		reverse_proxy reverb:9000
	}

	handle {
		reverse_proxy backend:8000
	}
}

{$REVERB_DOMAIN:hive-ws.gulfingot.com} {
	import security
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}

	reverse_proxy reverb:9000
}

{$HORIZON_DOMAIN:hive-queue.gulfingot.com} {
	import security
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}

	redir / /horizon 308
	reverse_proxy backend:8000
}

# Meilisearch and Grafana are intentionally NOT exposed publicly. The app reaches
# them over the private Docker network; for ops, use the 127.0.0.1-bound host ports
# from docker-compose.prod.yml via an SSH tunnel.
